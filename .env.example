OPENAI_API_KEY=your_openai_api_key

# Twilio Auth Token (Console → Account → API keys & tokens).
# When set, POST /twilio/voice requires a valid X-Twilio-Signature.
TWILIO_AUTH_TOKEN=
OPENAI_REALTIME_MODEL=gpt-realtime
ASSISTANT_INSTRUCTIONS=You are a friendly peer-like assistant on a live phone call. Be warm, concise, and practical.
OPENAI_VOICE=alloy
OPENAI_VAD_THRESHOLD=0.6
OPENAI_VAD_PREFIX_PADDING_MS=300
OPENAI_VAD_SILENCE_DURATION_MS=900
INPUT_AUDIO_TRANSCRIPTION_MODEL=whisper-1
INPUT_AUDIO_TRANSCRIPTION_LANGUAGE=en
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=2
WEB_SEARCH_DDGS_TIMEOUT=10
WEB_SEARCH_HTTP_TIMEOUT=12
WEB_SEARCH_MAX_RESPONSE_BYTES=2000000
WEB_SEARCH_MAX_EXTRACT_CHARS=8000
WEB_SEARCH_MAX_TOTAL_INPUT_CHARS=20000
WEB_SEARCH_SUMMARY_MODEL=gpt-4o-mini
WEB_SEARCH_SUMMARY_MAX_TOKENS=1400
WEB_SEARCH_SUMMARY_TEMPERATURE=0.35
WEB_SEARCH_USER_AGENT=
WEB_SEARCH_LOG_PREVIEW_CHARS=600
MEMORY_ENABLED=false
DATABASE_URL=postgresql://postgres:password@your-neon-host/voicechat?sslmode=require
MEMORY_RECENT_LIMIT=5
MEMORY_BOOTSTRAP_LIMIT=4
MEMORY_BOOTSTRAP_NOTE_MAX_CHARS=500
CALL_SUMMARY_ENABLED=true
CALL_SUMMARY_MODEL=gpt-4o-mini
CALL_SUMMARY_MAX_TOKENS=400
CALL_SUMMARY_TEMPERATURE=0.35
MEMORY_EMBEDDINGS_ENABLED=true
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_EMBEDDING_DIMS=1536
PUBLIC_BASE_URL=https://your-public-url.ngrok-free.app

